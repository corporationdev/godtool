{
  "name": "@executor/desktop",
  "version": "1.4.22",
  "private": true,
  "description": "GODTOOL desktop app",
  "homepage": "https://github.com/corporationdev/godtool",
  "author": {
    "name": "Rhys Sullivan",
    "email": "39114868+RhysSullivan@users.noreply.github.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc -p tsconfig.build.json",
    "bundle-cli": "node scripts/bundle-cli.js",
    "dist": "npm run build && npm run bundle-cli && electron-builder",
    "dist:mac": "npm run build && npm run bundle-cli && electron-builder --mac",
    "dist:win": "npm run build && npm run bundle-cli && electron-builder --win",
    "dist:linux": "npm run build && npm run bundle-cli && electron-builder --linux",
    "typecheck": "tsgo --noEmit",
    "typecheck:slow": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "35.7.5",
    "electron-builder": "^26.0.12",
    "typescript": "catalog:"
  },
  "build": {
    "appId": "com.godtool.desktop",
    "productName": "GODTOOL",
    "publish": null,
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "",
        "filter": [
          "executor*",
          "emscripten-module.wasm",
          "agent-browser/**",
          "computer-use/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icons"
    },
    "dmg": {
      "title": "GODTOOL",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
