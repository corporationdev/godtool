{
  "name": "@executor/marketing",
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "sh -lc 'if [ \"$CI\" != \"true\" ]; then echo \"Production deploys run in CI only.\" >&2; exit 1; fi; bun run --cwd ../cloud deploy:ci'",
    "deploy:dry-run": "astro build && wrangler deploy --config dist/server/wrangler.json --dry-run",
    "astro": "astro",
    "typecheck": "tsgo --noEmit",
    "typecheck:slow": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.0.0",
    "@astrojs/react": "^5.0.4",
    "@executor/plugin-google-discovery": "workspace:*",
    "@executor/plugin-graphql": "workspace:*",
    "@executor/plugin-openapi": "workspace:*",
    "@executor/sdk": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.3",
    "effect": "^3.14.16",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "portless": "^0.10.1",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
