---
export const prerender = true
import Layout from '../layouts/Layout.astro'

const repo = 'corporationdev/godtool'
const arm64Url = `https://github.com/${repo}/releases/latest/download/GODTOOL-mac-arm64.dmg`
const x64Url = `https://github.com/${repo}/releases/latest/download/GODTOOL-mac-x64.dmg`
const releasesUrl = `https://github.com/${repo}/releases/latest`
---

<Layout
  title="Download GOD TOOL"
  description="Download GOD TOOL for Apple Silicon or Intel Macs."
>
  <main class="min-h-screen px-6 py-12 sm:px-10">
    <div class="mx-auto max-w-xl">
      <a href="/" class="font-display text-xl italic tracking-tight text-ink transition-colors hover:text-teal">GOD TOOL</a>

      <section class="pt-24 sm:pt-32">
        <h1 class="font-display text-[clamp(2.5rem,8vw,4.5rem)] leading-none tracking-tight text-ink">
          Download
        </h1>
        <p class="mt-5 text-[15px] leading-7 text-ink-muted">
          Choose the Mac build for your processor.
        </p>

        <div class="mt-10 grid gap-3">
          <a
            href={arm64Url}
            class="inline-flex h-14 items-center justify-between rounded-md bg-teal px-5 text-[15px] font-medium text-surface transition-colors hover:bg-teal-dim"
          >
            <span>Apple Silicon</span>
            <span class="text-[12px] opacity-75">M1/M2/M3/M4</span>
          </a>
          <a
            href={x64Url}
            class="inline-flex h-14 items-center justify-between rounded-md border border-rule bg-surface-raised px-5 text-[15px] font-medium text-ink transition-colors hover:border-ink-faint hover:bg-surface-overlay"
          >
            <span>Intel Mac</span>
            <span class="text-[12px] text-ink-faint">older Macs</span>
          </a>
        </div>

        <p class="mt-6 text-[13px] leading-6 text-ink-faint">
          Not sure? Apple menu, About This Mac. If it says Apple M-series, use Apple Silicon.
          <a href={releasesUrl} class="ml-1 underline decoration-rule underline-offset-2 transition-colors hover:text-ink">All release files</a>
        </p>
      </section>
    </div>
  </main>
</Layout>
