      },
      axiom: {
        name: 'Axiom', count: 17, tools: [
          { name: 'datasets.query', desc: 'Query datasets using APL', policy: 'read', method: 'tool' },
          { name: 'datasets.list', desc: 'List all available datasets', policy: 'read', method: 'tool' },
          { name: 'datasets.fields', desc: 'List all fields in a dataset', policy: 'read', method: 'tool' },
          { name: 'datasets.info', desc: 'Get dataset metadata and stats', policy: 'read', method: 'tool' },
          { name: 'datasets.create', desc: 'Create a new dataset', policy: 'write', method: 'tool' },
          { name: 'datasets.trim', desc: 'Trim data from a dataset', policy: 'destructive', method: 'tool' },
          { name: 'monitors.list', desc: 'List all monitors', policy: 'read', method: 'tool' },
          { name: 'monitors.check', desc: 'Check monitor statuses', policy: 'read', method: 'tool' },
          { name: 'monitors.create', desc: 'Create a new monitor', policy: 'write', method: 'tool' },
          { name: 'dashboards.list', desc: 'List all dashboards', policy: 'read', method: 'tool' },
          { name: 'dashboards.get', desc: 'Get dashboard by ID', policy: 'read', method: 'tool' },
          { name: 'dashboards.create', desc: 'Create a new dashboard', policy: 'write', method: 'tool' },
          { name: 'dashboards.delete', desc: 'Delete a dashboard by UID', policy: 'destructive', method: 'tool' },
          { name: 'annotations.list', desc: 'List all annotations', policy: 'read', method: 'tool' },
          { name: 'annotations.create', desc: 'Create an annotation', policy: 'write', method: 'tool' },
        ]
      },
    };

    const policyClass = {
      read: 'text-teal/60 bg-teal/[0.06]',
      write: 'text-amber-300/60 bg-amber-300/[0.06]',
      destructive: 'text-red-400/60 bg-red-400/[0.06]',
    };

    const methodClass = {
      GET: 'text-teal/60',
      POST: 'text-amber-300/60',
      PUT: 'text-amber-300/60',
      PATCH: 'text-amber-300/60',
      DELETE: 'text-red-400/60',
      query: 'text-teal/60',
      mutation: 'text-amber-300/60',
      tool: 'text-ink-faint',
    };

    const catalog = document.getElementById('catalog-demo');
    const toolList = catalog?.querySelector('[data-tool-list]');
    const fadeEl = catalog?.querySelector('[data-fade]');
    const breadcrumb = catalog?.querySelector('[data-breadcrumb]');
    const totalTools = catalog?.querySelector('[data-total-tools]');
    const toolSearch = catalog?.querySelector('[data-tool-search]');
    let activeSourceId = 'github';

    function updateCatalogFade() {
      if (!toolList || !fadeEl) return;
      const atBottom = toolList.scrollHeight - toolList.scrollTop - toolList.clientHeight < 8;
      const noOverflow = toolList.scrollHeight <= toolList.clientHeight;
      fadeEl.style.opacity = atBottom || noOverflow ? '0' : '1';
    }

    toolList?.addEventListener('scroll', updateCatalogFade);

    function renderTools(sourceId, query = '') {
      const source = sources[sourceId] || sources.github;
      if (!toolList) return;
      activeSourceId = sourceId;
      if (breadcrumb) breadcrumb.textContent = source.name;
      if (totalTools) totalTools.textContent = `${source.count} actions available`;
      if (toolSearch instanceof HTMLInputElement) {
        toolSearch.placeholder = `Search ${source.count} actions...`;
      }

      const normalizedQuery = query.trim().toLowerCase();
      const matchingTools = source.tools.filter((tool) => {
        if (!normalizedQuery) return true;
        return `${tool.name} ${tool.desc} ${tool.policy} ${tool.method}`.toLowerCase().includes(normalizedQuery);
      });

      const renderRow = (tool) => `
        <div class="grid grid-cols-[1fr_auto_auto] gap-3 border-b border-rule px-4 py-3 transition-colors hover:bg-surface-overlay/50">
          <div class="min-w-0">
            <div class="truncate font-mono text-[12px] text-ink">${tool.name}</div>
            <div class="mt-0.5 truncate text-[12px] text-ink-faint">${tool.desc}</div>
          </div>
          <span class="self-center rounded px-2 py-1 font-mono text-[10px] ${policyClass[tool.policy] || policyClass.read}">${tool.policy}</span>
          <span class="hidden self-center font-mono text-[10px] ${methodClass[tool.method] || 'text-ink-faint'} sm:block">${tool.method}</span>
        </div>
      `;

      if (matchingTools.length === 0) {
        toolList.innerHTML = '<div class="px-4 py-8 text-center text-[12px] text-ink-faint">No matching actions</div>';
        updateCatalogFade();
        return;
      }

      if (normalizedQuery) {
        toolList.innerHTML = matchingTools.map(renderRow).join('');
        toolList.scrollTop = 0;
        updateCatalogFade();
        return;
      }

      const tree = {};
      for (const tool of source.tools) {
        const parts = tool.name.split('.');
        let node = tree;
        for (let i = 0; i < parts.length - 1; i++) {
          if (!node[parts[i]]) node[parts[i]] = { _children: {} };
          node = node[parts[i]]._children;
        }
        node[parts[parts.length - 1]] = { _tool: tool };
      }

      function renderTree(node, depth = 0) {
        let html = '';
        const keys = Object.keys(node);
        keys.forEach((key, index) => {
          const entry = node[key];
          const connector = index === keys.length - 1 ? '└' : '├';
          const indent = depth * 20;

          if (entry._tool) {
            const tool = entry._tool;
            html += `<div class="flex items-center gap-3 py-1.5 pr-4 transition-colors hover:bg-surface-overlay/50" style="padding-left:${16 + indent}px">
              <span class="w-3 shrink-0 select-none font-mono text-[11px] text-ink-faint">${depth > 0 ? connector : '·'}</span>
              <div class="min-w-0 flex-1">
                <div class="truncate font-mono text-[12px] text-ink">${key}</div>
                <div class="truncate text-[11px] text-ink-faint">${tool.desc}</div>
              </div>
              <span class="shrink-0 rounded px-1.5 py-0.5 font-mono text-[10px] ${policyClass[tool.policy] || policyClass.read}">${tool.policy}</span>
              <span class="hidden w-14 shrink-0 text-right font-mono text-[10px] ${methodClass[tool.method] || 'text-ink-faint'} sm:block">${tool.method}</span>
            </div>`;
          } else {
            const childCount = Object.keys(entry._children).length;
            html += `<div class="flex items-center gap-3 py-1.5 pr-4" style="padding-left:${16 + indent}px">
              <span class="w-3 shrink-0 select-none font-mono text-[11px] text-ink-faint">${depth > 0 ? connector : '▸'}</span>
              <span class="font-mono text-[12px] text-ink-muted">${key}</span>
              <span class="text-[10px] text-ink-faint">${childCount}</span>
            </div>`;
            html += renderTree(entry._children, depth + 1);
          }
        });
        return html;
      }

      toolList.innerHTML = renderTree(tree);
      toolList.scrollTop = 0;
      updateCatalogFade();
    }

    document.querySelectorAll('.catalog-source').forEach((button) => {
      button.addEventListener('click', () => {
        document.querySelectorAll('.catalog-source').forEach((item) => {
          item.classList.remove('border-teal/15', 'bg-teal/[0.08]');
          item.classList.add('border-transparent');
        });
        button.classList.add('border-teal/15', 'bg-teal/[0.08]');
        button.classList.remove('border-transparent');
        if (toolSearch instanceof HTMLInputElement) toolSearch.value = '';
        renderTools(button.dataset.source || 'github');
      });
    });

    toolSearch?.addEventListener('input', () => {
      renderTools(activeSourceId, toolSearch instanceof HTMLInputElement ? toolSearch.value : '');
    });

    renderTools('github');

    const detectInput = document.getElementById('detect-input');
    const detectButton = document.getElementById('detect-btn');
    const detectStatus = document.getElementById('detect-status');

    function setStatus(text, tone) {
      if (!detectStatus) return;
      detectStatus.textContent = text;
      detectStatus.className = `mt-3 text-center font-mono text-[11px] ${tone === 'ok' ? 'text-teal' : tone === 'bad' ? 'text-red-400' : 'text-ink-faint'}`;
    }

    async function detectUrl(url) {
      if (!url || !detectButton) return;
      detectButton.disabled = true;
      setStatus('Detecting source...', 'idle');
      try {
        const response = await fetch(`/api/detect?url=${encodeURIComponent(url)}`);
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data.error || 'Could not detect source');
        setStatus(`Detected ${data.kind}: ${data.name} with ${data.toolCount} actions`, 'ok');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'Could not detect source', 'bad');
      } finally {
        detectButton.disabled = false;
      }
    }

    detectButton?.addEventListener('click', () => {
      if (detectInput instanceof HTMLInputElement) void detectUrl(detectInput.value.trim());
    });

    detectInput?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && detectInput instanceof HTMLInputElement) {
        void detectUrl(detectInput.value.trim());
      }
    });

    document.querySelectorAll('.detect-example').forEach((button) => {
      button.addEventListener('click', () => {
        if (detectInput instanceof HTMLInputElement) {
          detectInput.value = button.dataset.url || '';
          void detectUrl(detectInput.value);
        }
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</Layout>
