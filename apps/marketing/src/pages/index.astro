  <script>
    const sources = {
      github: {
        name: 'GitHub',
        count: 347,
        tools: [
          ['issues.list', 'List repository issues', 'read', 'GET'],
          ['issues.create', 'Create a new issue', 'write', 'POST'],
          ['pulls.create', 'Open a pull request', 'write', 'POST'],
          ['pulls.merge', 'Merge a pull request', 'destructive', 'PUT'],
          ['actions.runs.list', 'List workflow runs', 'read', 'GET'],
          ['actions.runs.cancel', 'Cancel a workflow run', 'destructive', 'POST'],
        ],
      },
      slack: {
        name: 'Slack',
        count: 42,
        tools: [
          ['chat.postMessage', 'Send a message to a channel', 'write', 'POST'],
          ['conversations.history', 'Read channel history', 'read', 'GET'],
          ['files.upload', 'Upload a file', 'write', 'POST'],
          ['reactions.add', 'Add a reaction', 'write', 'POST'],
        ],
      },
      calendar: {
        name: 'Calendar',
        count: 18,
        tools: [
          ['events.list', 'List upcoming events', 'read', 'GET'],
          ['events.insert', 'Create a new event', 'write', 'POST'],
          ['freebusy.query', 'Check availability', 'read', 'POST'],
        ],
      },
      linear: {
        name: 'Linear',
        count: 56,
        tools: [
          ['issues.list', 'List issues with filters', 'read', 'query'],
          ['issues.create', 'Create a new issue', 'write', 'mutation'],
          ['comments.create', 'Add a comment', 'write', 'mutation'],
        ],
      },
      resend: {
        name: 'Resend',
        count: 19,
        tools: [
          ['emails.send', 'Send a transactional email', 'write', 'POST'],
          ['domains.verify', 'Verify a domain', 'write', 'POST'],
          ['contacts.list', 'List audience contacts', 'read', 'GET'],
        ],
      },
      axiom: {
        name: 'Axiom',
        count: 17,
        tools: [
          ['datasets.query', 'Query logs with APL', 'read', 'tool'],
          ['monitors.create', 'Create a monitor', 'write', 'tool'],
          ['dashboards.get', 'Read dashboard metadata', 'read', 'tool'],
        ],
      },
    };

    const policyClass = {
      read: 'text-teal/70 bg-teal/[0.06]',
      write: 'text-amber-300/70 bg-amber-300/[0.06]',
      destructive: 'text-red-400/70 bg-red-400/[0.06]',
    };

    const catalog = document.getElementById('catalog-demo');
    const toolList = catalog?.querySelector('[data-tool-list]');
    const breadcrumb = catalog?.querySelector('[data-breadcrumb]');
    const totalTools = catalog?.querySelector('[data-total-tools]');
    const searchLabel = catalog?.querySelector('[data-search-label]');

    function renderTools(sourceId) {
      const source = sources[sourceId] || sources.github;
      if (!toolList) return;
      if (breadcrumb) breadcrumb.textContent = source.name;
      if (totalTools) totalTools.textContent = `${source.count} actions available`;
      if (searchLabel) searchLabel.textContent = `Search ${source.count} actions...`;
      toolList.innerHTML = source.tools
        .concat(source.tools, source.tools)
        .map(([name, desc, policy, method]) => `
          <div class="grid grid-cols-[1fr_auto_auto] gap-3 border-b border-rule px-4 py-3">
            <div class="min-w-0">
              <div class="truncate font-mono text-[12px] text-ink">${name}</div>
              <div class="mt-0.5 truncate text-[12px] text-ink-faint">${desc}</div>
            </div>
            <span class="self-center rounded px-2 py-1 font-mono text-[10px] ${policyClass[policy] || policyClass.read}">${policy}</span>
            <span class="hidden self-center font-mono text-[10px] text-ink-faint sm:block">${method}</span>
          </div>
        `)
        .join('');
    }

    document.querySelectorAll('.catalog-source').forEach((button) => {
      button.addEventListener('click', () => {
        document.querySelectorAll('.catalog-source').forEach((item) => {
          item.classList.remove('border-teal/15', 'bg-teal/[0.08]');
          item.classList.add('border-transparent');
        });
        button.classList.add('border-teal/15', 'bg-teal/[0.08]');
        button.classList.remove('border-transparent');
        renderTools(button.dataset.source);
      });
    });
    renderTools('github');

    const detectInput = document.getElementById('detect-input');
    const detectButton = document.getElementById('detect-btn');
    const detectStatus = document.getElementById('detect-status');

    function setStatus(text, tone) {
      if (!detectStatus) return;
      detectStatus.textContent = text;
      detectStatus.className = `mt-3 text-center font-mono text-[11px] ${tone === 'ok' ? 'text-teal' : tone === 'bad' ? 'text-red-400' : 'text-ink-faint'}`;
    }

    async function detectUrl(url) {
      if (!url || !detectButton) return;
      detectButton.disabled = true;
      setStatus('Detecting source...', 'idle');
      try {
        const response = await fetch(`/api/detect?url=${encodeURIComponent(url)}`);
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data.error || 'Could not detect source');
        setStatus(`Detected ${data.kind}: ${data.name} with ${data.toolCount} actions`, 'ok');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'Could not detect source', 'bad');
      } finally {
        detectButton.disabled = false;
      }
    }

    detectButton?.addEventListener('click', () => {
      if (detectInput instanceof HTMLInputElement) void detectUrl(detectInput.value.trim());
    });

    detectInput?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && detectInput instanceof HTMLInputElement) {
        void detectUrl(detectInput.value.trim());
      }
    });

    document.querySelectorAll('.detect-example').forEach((button) => {
      button.addEventListener('click', () => {
        if (detectInput instanceof HTMLInputElement) {
          detectInput.value = button.dataset.url || '';
          void detectUrl(detectInput.value);
        }
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
