---
export const prerender = true
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="GOD TOOL"
  description="Give every agent the same interface to your connected accounts, logged-in browsers, persistent files, and Mac computer-use."
>
  <nav class="fixed top-0 z-50 w-full border-b border-rule bg-surface/80 backdrop-blur-lg">
    <div class="mx-auto flex h-14 max-w-[1200px] items-center justify-between px-6 sm:px-10">
      <a href="/" class="font-display text-xl italic tracking-tight text-ink transition-colors hover:text-teal">GOD TOOL</a>
      <div class="flex items-center gap-8">
        <a href="#integrations" class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:block">Integrations</a>
        <a href="#computer" class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:block">Computer use</a>
        <a href="https://github.com/RhysSullivan/executor" class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:block">GitHub</a>
        <a href="/setup" class="rounded-md bg-teal px-4 py-1.5 text-[13px] font-medium text-surface transition-colors hover:bg-teal-dim">
          Download for free
        </a>
      </div>
    </div>
  </nav>

  <section class="relative flex min-h-screen flex-col justify-center overflow-hidden pt-24 sm:pt-28">
    <div class="pointer-events-none absolute right-[8%] top-[14%] h-[520px] w-[520px] rounded-full bg-teal/[0.04] blur-[150px]"></div>

    <div class="mx-auto w-full max-w-[1200px] px-6 sm:px-10">
      <div class="mx-auto mb-14 max-w-[980px] text-center">
        <p class="rise-d1 mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-teal/70">
          Shared execution layer
        </p>
        <h1 class="rise-d1 mb-7 font-display text-[clamp(2.75rem,5.8vw,5rem)] leading-[0.98] tracking-tight text-ink">
          Give every agent the same <span class="italic text-teal">interface to the world.</span>
        </h1>
        <p class="rise-d2 mx-auto max-w-[720px] text-[17px] leading-[1.7] text-ink-muted">
          One setup for connected accounts, logged-in browsers, persistent files, and Mac computer-use. Works from Claude Code, Codex, Cursor, and any MCP client.
        </p>
        <div class="rise-d3 mt-9 flex flex-wrap items-center justify-center gap-4">
          <a href="/setup" class="inline-flex items-center gap-2 rounded-md bg-teal px-5 py-2.5 text-[14px] font-medium text-surface transition-colors hover:bg-teal-dim">
            Download for free
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5h6m0 0v6m0-6-9 9" /></svg>
          </a>
          <a href="https://github.com/RhysSullivan/executor" class="inline-flex items-center gap-2 rounded-md border border-rule px-5 py-2.5 text-[14px] text-ink-muted transition-colors hover:border-ink-faint hover:text-ink">
            View on GitHub
          </a>
        </div>
      </div>

      <div class="rise-d4 overflow-hidden rounded-2xl border border-rule bg-surface-raised p-4 shadow-2xl shadow-black/10 sm:p-6 lg:p-8">
        <div class="grid gap-6 lg:grid-cols-[220px_72px_minmax(220px,1fr)_72px_280px] lg:items-center">
          <div class="grid gap-3">
            <div class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Agent clients</div>
            {[
              { name: 'Claude Code', detail: 'MCP client', icon: 'https://www.google.com/s2/favicons?domain=claude.ai&sz=64' },
              { name: 'Codex', detail: 'MCP client', icon: 'https://www.google.com/s2/favicons?domain=openai.com&sz=64' },
              { name: 'Cursor', detail: 'MCP client', icon: 'https://www.google.com/s2/favicons?domain=cursor.com&sz=64' },
            ].map((agent) => (
              <div class="flex min-h-[76px] items-center gap-3 rounded-lg border border-rule bg-surface px-3 py-3">
                <img src={agent.icon} alt="" class="h-8 w-8 rounded-md bg-white p-1" loading="lazy" />
                <div class="min-w-0">
                  <div class="truncate text-[13px] font-medium text-ink">{agent.name}</div>
                  <div class="mt-0.5 text-[11px] text-ink-faint">{agent.detail}</div>
                </div>
              </div>
            ))}
            <div class="flex min-h-[76px] items-center gap-3 rounded-lg border border-rule bg-surface px-3 py-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-teal/20 bg-teal/[0.07] font-mono text-[10px] text-teal">MCP</span>
              <div class="min-w-0">
                <div class="truncate text-[13px] font-medium text-ink">Any MCP client</div>
                <div class="mt-0.5 text-[11px] text-ink-faint">same endpoint</div>
              </div>
            </div>
          </div>

          <div class="hidden gap-3 pt-[34px] lg:grid">
            {Array.from({ length: 4 }).map(() => (
              <div class="flex min-h-[76px] items-center text-teal/45">
                <span class="h-px flex-1 bg-gradient-to-r from-transparent via-teal/50 to-teal/70"></span>
                <svg class="ml-1 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 6 6 6-6 6" /></svg>
              </div>
            ))}
          </div>

          <div class="relative">
            <div class="absolute inset-0 rounded-[2rem] bg-teal/10 blur-3xl"></div>
            <div class="relative flex min-h-[260px] flex-col items-center justify-center rounded-2xl border border-teal/25 bg-surface px-6 py-8 text-center">
              <span class="flex h-16 w-16 items-center justify-center rounded-2xl border border-teal/20 bg-ink p-3 shadow-lg shadow-black/20" aria-hidden="true">
                <span
                  class="h-full w-full bg-surface"
                  style="-webkit-mask: url('/favicon.svg') center / contain no-repeat; mask: url('/favicon.svg') center / contain no-repeat;"
                ></span>
              </span>
              <div class="mt-5 font-display text-[28px] font-semibold tracking-tight text-ink">GOD TOOL</div>
              <div class="mt-2 font-mono text-[11px] uppercase tracking-[0.18em] text-teal">Shared execution layer</div>
              <div class="mt-5 h-px w-28 bg-gradient-to-r from-transparent via-teal/60 to-transparent"></div>
              <div class="mt-5 max-w-[220px] text-[12px] leading-5 text-ink-faint">
                One interface every agent can call.
              </div>
            </div>
          </div>

          <div class="hidden gap-3 pt-[34px] lg:grid">
            {Array.from({ length: 4 }).map(() => (
              <div class="flex min-h-[76px] items-center text-teal/45">
                <span class="h-px flex-1 bg-gradient-to-r from-teal/70 via-teal/50 to-transparent"></span>
                <svg class="ml-1 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 6 6 6-6 6" /></svg>
              </div>
            ))}
          </div>

          <div class="grid gap-3">
            <div class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">The world</div>
            <div class="flex min-h-[76px] items-center gap-3 rounded-lg border border-rule bg-surface p-3">
              <div class="relative h-9 w-[70px] shrink-0">
                <img src="/logos/github.svg" alt="" class="absolute left-0 top-1 h-8 w-8 rounded-md bg-white p-1" loading="lazy" />
                <img src="/logos/slack.svg" alt="" class="absolute left-5 top-0 h-8 w-8 rounded-md bg-white p-1" loading="lazy" />
                <img src="/logos/gmail.svg" alt="" class="absolute left-10 top-1 h-8 w-8 rounded-md bg-white p-1" loading="lazy" />
              </div>
              <div class="min-w-0">
                <div class="truncate text-[13px] font-medium text-ink">Connected accounts</div>
                <div class="mt-0.5 truncate text-[11px] text-ink-faint">GitHub, Slack, Gmail, and more</div>
              </div>
            </div>
            <div class="flex min-h-[76px] items-center gap-3 rounded-lg border border-rule bg-surface p-3">
              <img src="https://www.google.com/s2/favicons?domain=google.com/chrome&sz=64" alt="" class="h-8 w-8 rounded-md bg-white p-1" loading="lazy" />
              <div class="min-w-0">
                <div class="truncate text-[13px] font-medium text-ink">Logged-in browsers</div>
                <div class="mt-0.5 text-[11px] text-ink-faint">persistent sessions</div>
              </div>
            </div>
            <div class="flex min-h-[76px] items-center gap-3 rounded-lg border border-rule bg-surface p-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-rule bg-surface-raised text-teal">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5.5h16v10.25H4zM9 19h6m-3-3.25V19" /></svg>
              </span>
              <div class="min-w-0">
                <div class="truncate text-[13px] font-medium text-ink">Mac computer-use</div>
                <div class="mt-0.5 text-[11px] text-ink-faint">act on your machine</div>
              </div>
            </div>
            <div class="flex min-h-[76px] items-center gap-3 rounded-lg border border-rule bg-surface p-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-rule bg-surface-raised text-teal">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 7.5h6l1.5 2h9v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5z" /><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 7.5V6a1.5 1.5 0 0 1 1.5-1.5h4.5l1.5 2h7.5a1.5 1.5 0 0 1 1.5 1.5v1.5" /></svg>
              </span>
              <div class="min-w-0">
                <div class="truncate text-[13px] font-medium text-ink">Persistent files</div>
                <div class="mt-0.5 text-[11px] text-ink-faint">shared agent context</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="integrations" class="relative py-28 sm:py-36">
    <div class="mx-auto max-w-[1200px] px-6 sm:px-10">
      <div class="reveal mb-12 grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
        <div>
          <span class="mb-4 block font-mono text-[11px] uppercase tracking-[0.2em] text-ink-faint">Integrations</span>
          <h2 class="max-w-[640px] font-display text-[clamp(2.5rem,4.2vw,4.1rem)] leading-[1] tracking-tight text-ink">
            Connect once.<br /><span class="italic text-teal">Use everywhere.</span>
          </h2>
        </div>
        <p class="max-w-2xl pb-2 text-[15px] leading-7 text-ink-muted">
          Add OpenAPI, GraphQL, Google Discovery, MCP, and local tools in one place. Every connected agent gets the same catalog, credentials, and policies. Cloud integrations stay available even when your Mac is closed.
        </p>
      </div>

      <div class="reveal mb-4" id="detect-bar">
        <div class="flex flex-col gap-3 rounded-xl border border-rule bg-surface-raised p-4 sm:flex-row sm:items-center">
          <div class="flex min-w-0 flex-1 items-center gap-3 rounded-lg border border-rule bg-surface px-3 py-2.5">
            <svg class="h-4 w-4 shrink-0 text-ink-faint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.414-5.874a4.5 4.5 0 0 0-6.364 0l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>
            <input
              id="detect-input"
              type="url"
              placeholder="Paste an API URL to detect actions..."
              class="min-w-0 flex-1 bg-transparent font-mono text-[13px] text-ink outline-none placeholder:text-ink-faint"
              autocomplete="off"
              spellcheck="false"
            />
          </div>
          <button id="detect-btn" class="rounded-md bg-teal px-4 py-2.5 text-[13px] font-medium text-surface transition-colors hover:bg-teal-dim disabled:cursor-not-allowed disabled:opacity-40">
            Detect
          </button>
        </div>
        <div id="detect-status" class="mt-3 hidden text-center font-mono text-[11px]"></div>
        <div class="mt-3 flex flex-wrap items-center justify-center gap-2">
          <span class="text-[11px] text-ink-faint">Try:</span>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://raw.githubusercontent.com/github/rest-api-description/main/descriptions/api.github.com/api.github.com.json">GitHub REST</button>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://api.linear.app/graphql">Linear GraphQL</button>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest">Google Calendar</button>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://raw.githubusercontent.com/stripe/openapi/master/openapi/spec3.json">Stripe</button>
        </div>
      </div>

      <div class="reveal overflow-hidden rounded-xl border border-rule bg-surface-raised" id="catalog-demo">
        <div class="flex items-center justify-between border-b border-rule px-5 py-3">
          <div class="flex items-center gap-3">
            <span class="font-display text-sm italic text-ink">GOD TOOL</span>
            <span class="text-ink-faint">/</span>
            <span class="text-ink-muted">Sources</span>
            <span class="text-ink-faint">/</span>
            <span class="text-ink" data-breadcrumb>GitHub</span>
          </div>
          <span class="font-mono text-[11px] text-teal" data-total-tools>482 actions available</span>
        </div>

        <div class="flex">
          <div class="hidden w-[210px] shrink-0 border-r border-rule p-3 sm:block">
            <div class="mb-2.5 px-2 font-mono text-[10px] uppercase tracking-[0.1em] text-ink-faint">Connected</div>
            {[
              ['github', 'GitHub', '347 actions', 'github.com', 'api'],
              ['slack', 'Slack', '42 actions', 'slack.com', 'app'],
              ['calendar', 'Calendar', '18 actions', 'calendar.google.com', 'app'],
              ['linear', 'Linear', '56 actions', 'linear.app', 'app'],
              ['resend', 'Resend', '19 actions', 'resend.com', 'api'],
              ['axiom', 'Axiom', '17 actions', 'axiom.co', 'mcp'],
            ].map(([id, name, count, domain, tag], index) => (
              <button data-source={id} class={`catalog-source mb-1 flex w-full items-center gap-2.5 rounded-md border px-2 py-2 text-left transition-colors ${index === 0 ? 'border-teal/15 bg-teal/[0.08]' : 'border-transparent hover:bg-surface-overlay'}`}>
                <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md border border-rule bg-white">
                  <img src={`https://www.google.com/s2/favicons?domain=${domain}&sz=64`} alt="" class="h-4 w-4" loading="lazy" referrerpolicy="no-referrer" />
                </div>
                <div class="min-w-0 flex-1">
                  <div class={`truncate text-[12px] ${index === 0 ? 'text-ink' : 'text-ink-muted'}`}>{name}</div>
                  <div class="text-[10px] text-ink-faint">{count}</div>
                </div>
                <span class="shrink-0 font-mono text-[9px] text-ink-faint">{tag}</span>
              </button>
            ))}
          </div>

          <div class="min-w-0 flex-1">
            <div class="border-b border-rule px-4 py-3">
              <div class="flex items-center gap-2 rounded-md border border-rule bg-surface px-3 py-2 text-[12px] text-ink-faint">
                <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
                <input
                  data-tool-search
                  type="search"
                  placeholder="Search 347 actions..."
                  class="min-w-0 flex-1 bg-transparent text-[12px] text-ink outline-none placeholder:text-ink-faint"
                  autocomplete="off"
                />
              </div>
            </div>
            <div class="relative">
              <div class="h-[340px] overflow-y-auto scrollbar-thin" data-tool-list></div>
              <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-surface-raised to-transparent" data-fade></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="computer" class="relative border-y border-rule py-28 sm:py-36">
    <div class="mx-auto max-w-[1200px] px-6 sm:px-10">
      <div class="reveal mb-12 max-w-3xl">
        <span class="mb-4 block font-mono text-[11px] uppercase tracking-[0.2em] text-ink-faint">Computer + browser use</span>
        <h2 class="font-display text-[clamp(2.4rem,4.7vw,4.25rem)] leading-[1] tracking-tight text-ink">
          Use websites and native apps <span class="italic text-teal">from one controlled layer.</span>
        </h2>
        <p class="mt-6 max-w-2xl text-[15px] leading-7 text-ink-muted">
          GOD TOOL keeps logged-in browsers contained, runs Mac computer-use in the background, and lets useful routines become repeatable workflows.
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        <div class="reveal flex min-h-[320px] flex-col rounded-xl border border-rule bg-surface-raised p-5">
          <div class="mb-6 flex items-center justify-between">
            <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Browser use</span>
            <span class="rounded bg-teal/[0.08] px-2 py-1 font-mono text-[10px] text-teal">persistent auth</span>
          </div>
          <div class="flex h-[210px] flex-col justify-center rounded-xl border border-rule bg-surface p-4">
            <div class="grid grid-cols-2 gap-2">
              {[
                ['/logos/linkedin.svg', 'LinkedIn', 'profiles'],
                ['/logos/x.svg', 'X.com', 'posts'],
                ['/logos/instagram.svg', 'Instagram', 'media'],
                ['/logos/reddit.svg', 'Reddit', 'threads'],
              ].map(([icon, name, detail]) => (
                <div class="flex items-center gap-3 rounded-lg border border-rule bg-surface-raised px-3 py-2">
                  <img src={icon} alt="" class="h-8 w-8 shrink-0 rounded-lg object-contain" loading="lazy" />
                  <div class="min-w-0">
                    <div class="truncate text-[13px] font-medium text-ink">{name}</div>
                    <div class="mt-0.5 font-mono text-[10px] text-ink-faint">{detail}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-auto pt-8">
            <h3 class="text-[17px] font-medium text-ink">Use sites that do not fit an API.</h3>
            <p class="mt-3 text-[13px] leading-6 text-ink-muted">
              Keep logged-in browser sessions inside GOD TOOL for web apps where clicking is the interface.
            </p>
          </div>
        </div>

        <div class="reveal flex min-h-[320px] flex-col rounded-xl border border-rule bg-surface-raised p-5">
          <div class="mb-6 flex items-center justify-between">
            <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Mac computer-use</span>
            <span class="rounded bg-teal/[0.08] px-2 py-1 font-mono text-[10px] text-teal">background</span>
          </div>
          <div class="flex h-[210px] flex-col justify-center rounded-xl border border-rule bg-surface p-4">
            <div class="grid grid-cols-2 gap-2">
              {[
                ['DaVinci Resolve', 'trim timeline', '/logos/apps/davinci-resolve.png'],
                ['Messages', 'send reply', '/logos/apps/messages.png'],
                ['Notes', 'update note', '/logos/apps/notes.png'],
                ['Figma', 'edit design', '/logos/apps/figma.svg'],
              ].map(([name, detail, icon]) => (
                <div class="flex items-center gap-3 rounded-lg border border-rule bg-surface-raised px-3 py-2">
                  <img src={icon} alt="" class="h-8 w-8 shrink-0 rounded-lg object-contain" loading="lazy" />
                  <div class="min-w-0">
                    <div class="truncate text-[13px] font-medium text-ink">{name}</div>
                    <div class="mt-0.5 font-mono text-[10px] text-ink-faint">{detail}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-auto pt-8">
            <h3 class="text-[17px] font-medium text-ink">Run GUI-only Mac workflows.</h3>
            <p class="mt-3 text-[13px] leading-6 text-ink-muted">
              Agents can read screens, click controls, and type into desktop apps while you keep working.
            </p>
          </div>
        </div>

        <div class="reveal flex min-h-[320px] flex-col rounded-xl border border-rule bg-surface-raised p-5">
          <div class="mb-6 flex items-center justify-between">
            <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Workflows</span>
            <span class="rounded bg-teal/[0.08] px-2 py-1 font-mono text-[10px] text-teal">reusable</span>
          </div>
          <div class="flex h-[210px] flex-col justify-center rounded-xl border border-rule bg-surface p-4">
            <div class="grid gap-2">
              {[
                'Open logged-in browser',
                'Read profile',
                'Check company site',
                'Save notes',
              ].map((step, index) => (
                <div class="flex items-center gap-2 rounded-lg border border-rule bg-surface-raised px-3 py-2">
                  <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-teal/[0.08] font-mono text-[10px] text-teal">{index + 1}</span>
                  <span class="truncate text-[12px] text-ink-muted">{step}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-auto pt-8">
            <h3 class="text-[17px] font-medium text-ink">Save the workflow once.</h3>
            <p class="mt-3 text-[13px] leading-6 text-ink-muted">
              Turn browser and computer-use steps into repeatable routines your team can run again later.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-28 sm:py-36">
    <div class="mx-auto grid max-w-[1200px] gap-12 px-6 sm:px-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div class="reveal overflow-hidden rounded-xl border border-rule bg-surface-raised">
        <div class="flex items-center justify-between border-b border-rule px-4 py-3">
          <div class="font-mono text-[11px] text-ink-faint">/Users/you/GOD TOOL/workspace</div>
