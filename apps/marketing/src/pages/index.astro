---
export const prerender = true
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="GOD TOOL"
  description="Give every agent the same interface to your integrations, browser sessions, Mac actions, and shared local context."
>
  <nav class="fixed top-0 z-50 w-full border-b border-rule bg-surface/80 backdrop-blur-lg">
    <div class="mx-auto flex h-14 max-w-[1200px] items-center justify-between px-6 sm:px-10">
      <a href="/" class="font-display text-xl italic tracking-tight text-ink transition-colors hover:text-teal">GOD TOOL</a>
      <div class="flex items-center gap-8">
        <a href="#integrations" class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:block">Integrations</a>
        <a href="#computer" class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:block">Computer use</a>
        <a href="https://github.com/RhysSullivan/executor" class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:block">GitHub</a>
        <a href="#try" class="rounded-md bg-teal px-4 py-1.5 text-[13px] font-medium text-surface transition-colors hover:bg-teal-dim">
          Get started
        </a>
      </div>
    </div>
  </nav>

  <section class="relative flex min-h-screen flex-col justify-center overflow-hidden pt-24 sm:pt-28">
    <div class="pointer-events-none absolute right-[8%] top-[14%] h-[520px] w-[520px] rounded-full bg-teal/[0.04] blur-[150px]"></div>

    <div class="mx-auto w-full max-w-[1200px] px-6 sm:px-10">
      <div class="mx-auto mb-14 max-w-[940px] text-center">
        <p class="rise-d1 mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-teal/70">
          Shared execution layer
        </p>
        <h1 class="rise-d1 mb-7 font-display text-[clamp(3rem,7vw,6rem)] leading-[0.95] tracking-tight text-ink">
          Give every agent the same <span class="italic text-teal">interface to the world.</span>
        </h1>
        <p class="rise-d2 mx-auto max-w-3xl text-[17px] leading-[1.7] text-ink-muted">
          Connect integrations, browsers, Mac actions, and shared context once. GOD TOOL exposes them through MCP so Claude, Codex, Cursor, phone clients, and custom agents can use the same environment.
        </p>
        <div class="rise-d3 mt-9 flex flex-wrap items-center justify-center gap-4">
          <a href="#try" class="inline-flex items-center gap-2 rounded-md bg-teal px-5 py-2.5 text-[14px] font-medium text-surface transition-colors hover:bg-teal-dim">
            Try the future of tool calling
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5h6m0 0v6m0-6-9 9" /></svg>
          </a>
          <a href="https://github.com/RhysSullivan/executor" class="inline-flex items-center gap-2 rounded-md border border-rule px-5 py-2.5 text-[14px] text-ink-muted transition-colors hover:border-ink-faint hover:text-ink">
            View on GitHub
          </a>
        </div>
      </div>

      <div class="rise-d4 grid gap-4 lg:grid-cols-[0.72fr_1.4fr_0.72fr]">
        <div class="hidden flex-col gap-3 rounded-xl border border-rule bg-surface-raised p-4 lg:flex">
          <div class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Agents</div>
          <div class="rounded-lg border border-rule bg-surface p-3">
            <div class="text-[13px] font-medium text-ink">Claude Code</div>
            <div class="mt-1 text-[11px] text-ink-faint">MCP client</div>
          </div>
          <div class="rounded-lg border border-rule bg-surface p-3">
            <div class="text-[13px] font-medium text-ink">Codex</div>
            <div class="mt-1 text-[11px] text-ink-faint">MCP client</div>
          </div>
          <div class="rounded-lg border border-rule bg-surface p-3">
            <div class="text-[13px] font-medium text-ink">Cursor</div>
            <div class="mt-1 text-[11px] text-ink-faint">MCP client</div>
          </div>
          <div class="rounded-lg border border-teal/20 bg-teal/[0.05] p-3">
            <div class="text-[13px] font-medium text-teal">Phone agent</div>
            <div class="mt-1 text-[11px] text-teal/60">same endpoint</div>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl border border-rule bg-surface-raised shadow-2xl shadow-black/10">
          <div class="flex items-center justify-between border-b border-rule px-4 py-3">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
            </div>
            <div class="font-mono text-[11px] text-ink-faint">GOD TOOL MCP</div>
          </div>

          <div class="grid min-h-[390px] md:grid-cols-[190px_1fr]">
            <aside class="hidden border-r border-rule bg-sidebar p-3 md:block">
              <div class="mb-3 px-2 font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Sources</div>
              {['GitHub', 'Slack', 'Google Calendar', 'Linear', 'Stripe'].map((name, index) => (
                <div class={`mb-1 flex items-center gap-2 rounded-md px-2 py-2 text-[12px] ${index === 0 ? 'bg-sidebar-active text-ink' : 'text-ink-muted'}`}>
                  <span class="flex h-5 w-5 items-center justify-center rounded border border-rule bg-surface text-[10px] text-teal">{name[0]}</span>
                  <span class="truncate">{name}</span>
                </div>
              ))}
            </aside>

            <main class="flex min-w-0 flex-col">
              <div class="border-b border-rule px-4 py-3">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <div class="text-[14px] font-medium text-ink">Shared action catalog</div>
                    <div class="mt-1 text-[12px] text-ink-faint">482 typed actions available to every agent</div>
                  </div>
                  <span class="rounded-md border border-teal/20 bg-teal/[0.07] px-2 py-1 font-mono text-[10px] text-teal">online</span>
                </div>
              </div>

              <div class="grid gap-px bg-rule text-[12px]">
                <div class="grid grid-cols-[1fr_auto] gap-3 bg-surface-raised px-4 py-3">
                  <div class="min-w-0">
                    <div class="truncate font-mono text-[12px] text-ink">issues.create</div>
                    <div class="mt-0.5 truncate text-[12px] text-ink-faint">Create a GitHub issue</div>
                  </div>
                  <span class="self-center rounded bg-amber-300/[0.06] px-2 py-1 font-mono text-[10px] text-amber-300/70">write</span>
                </div>
                <div class="grid grid-cols-[1fr_auto] gap-3 bg-surface-raised px-4 py-3">
                  <div class="min-w-0">
                    <div class="truncate font-mono text-[12px] text-ink">chat.postMessage</div>
                    <div class="mt-0.5 truncate text-[12px] text-ink-faint">Send a Slack message</div>
                  </div>
                  <span class="self-center rounded bg-amber-300/[0.06] px-2 py-1 font-mono text-[10px] text-amber-300/70">write</span>
                </div>
                <div class="grid grid-cols-[1fr_auto] gap-3 bg-surface-raised px-4 py-3">
                  <div class="min-w-0">
                    <div class="truncate font-mono text-[12px] text-ink">events.list</div>
                    <div class="mt-0.5 truncate text-[12px] text-ink-faint">Read calendar events</div>
                  </div>
                  <span class="self-center rounded bg-teal/[0.06] px-2 py-1 font-mono text-[10px] text-teal/70">read</span>
                </div>
                <div class="grid grid-cols-[1fr_auto] gap-3 bg-surface-raised px-4 py-3">
                  <div class="min-w-0">
                    <div class="truncate font-mono text-[12px] text-ink">browser.open</div>
                    <div class="mt-0.5 truncate text-[12px] text-ink-faint">Start an embedded browser</div>
                  </div>
                  <span class="self-center rounded bg-blue-400/[0.08] px-2 py-1 font-mono text-[10px] text-blue-300/75">local</span>
                </div>
                <div class="grid grid-cols-[1fr_auto] gap-3 bg-surface-raised px-4 py-3">
                  <div class="min-w-0">
                    <div class="truncate font-mono text-[12px] text-ink">computer.click</div>
                    <div class="mt-0.5 truncate text-[12px] text-ink-faint">Click on your Mac</div>
                  </div>
                  <span class="self-center rounded bg-blue-400/[0.08] px-2 py-1 font-mono text-[10px] text-blue-300/75">local</span>
                </div>
                <div class="grid grid-cols-[1fr_auto] gap-3 bg-surface-raised px-4 py-3">
                  <div class="min-w-0">
                    <div class="truncate font-mono text-[12px] text-ink">workspace.writeFile</div>
                    <div class="mt-0.5 truncate text-[12px] text-ink-faint">Save shared context</div>
                  </div>
                  <span class="self-center rounded bg-amber-300/[0.06] px-2 py-1 font-mono text-[10px] text-amber-300/70">write</span>
                </div>
              </div>
            </main>
          </div>
        </div>

        <div class="hidden flex-col gap-3 rounded-xl border border-rule bg-surface-raised p-4 lg:flex">
          <div class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Capabilities</div>
          {['Integrations', 'Embedded browsers', 'Mac actions', 'Shared memory', 'TypeScript tools'].map((name) => (
            <div class="rounded-lg border border-rule bg-surface p-3 text-[13px] text-ink-muted">{name}</div>
          ))}
          <div class="mt-auto rounded-lg border border-teal/20 bg-teal/[0.05] p-3">
            <div class="text-[13px] font-medium text-teal">One setup</div>
            <div class="mt-1 text-[11px] leading-5 text-teal/60">Every MCP client gets the same interface.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="integrations" class="relative py-28 sm:py-36">
    <div class="mx-auto max-w-[1200px] px-6 sm:px-10">
      <div class="reveal mb-12 grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div>
          <span class="mb-4 block font-mono text-[11px] uppercase tracking-[0.2em] text-ink-faint">Integrations</span>
          <h2 class="font-display text-[clamp(2rem,4.8vw,4rem)] leading-[1.02] tracking-tight text-ink">
            Connect once.<br /><span class="italic text-teal">Use everywhere.</span>
          </h2>
        </div>
        <p class="max-w-2xl text-[15px] leading-7 text-ink-muted">
          Add OpenAPI, GraphQL, Google Discovery, MCP, and local tools in one place. Every connected agent gets the same catalog, credentials, and policies. Cloud integrations stay available even when your Mac is closed.
        </p>
      </div>

      <div class="reveal mb-4" id="detect-bar">
        <div class="flex flex-col gap-3 rounded-xl border border-rule bg-surface-raised p-4 sm:flex-row sm:items-center">
          <div class="flex min-w-0 flex-1 items-center gap-3 rounded-lg border border-rule bg-surface px-3 py-2.5">
            <svg class="h-4 w-4 shrink-0 text-ink-faint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.414-5.874a4.5 4.5 0 0 0-6.364 0l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>
            <input
              id="detect-input"
              type="url"
              placeholder="Paste an API URL to detect actions..."
              class="min-w-0 flex-1 bg-transparent font-mono text-[13px] text-ink outline-none placeholder:text-ink-faint"
              autocomplete="off"
              spellcheck="false"
            />
          </div>
          <button id="detect-btn" class="rounded-md bg-teal px-4 py-2.5 text-[13px] font-medium text-surface transition-colors hover:bg-teal-dim disabled:cursor-not-allowed disabled:opacity-40">
            Detect
          </button>
        </div>
        <div id="detect-status" class="mt-3 hidden text-center font-mono text-[11px]"></div>
        <div class="mt-3 flex flex-wrap items-center justify-center gap-2">
          <span class="text-[11px] text-ink-faint">Try:</span>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://raw.githubusercontent.com/github/rest-api-description/main/descriptions/api.github.com/api.github.com.json">GitHub REST</button>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://api.linear.app/graphql">Linear GraphQL</button>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest">Google Calendar</button>
          <button class="detect-example rounded border border-rule px-2 py-1 font-mono text-[11px] text-teal/60 transition-colors hover:border-teal/20 hover:text-teal" data-url="https://raw.githubusercontent.com/stripe/openapi/master/openapi/spec3.json">Stripe</button>
        </div>
      </div>

      <div class="reveal overflow-hidden rounded-xl border border-rule bg-surface-raised" id="catalog-demo">
        <div class="flex items-center justify-between border-b border-rule px-5 py-3">
          <div class="flex items-center gap-3">
            <span class="font-display text-sm italic text-ink">GOD TOOL</span>
            <span class="text-ink-faint">/</span>
            <span class="text-ink-muted">Sources</span>
            <span class="text-ink-faint">/</span>
            <span class="text-ink" data-breadcrumb>GitHub</span>
          </div>
          <span class="font-mono text-[11px] text-teal" data-total-tools>482 actions available</span>
        </div>

        <div class="flex">
          <div class="hidden w-[210px] shrink-0 border-r border-rule p-3 sm:block">
            <div class="mb-2.5 px-2 font-mono text-[10px] uppercase tracking-[0.1em] text-ink-faint">Connected</div>
            {[
              ['github', 'GitHub', '347 actions', 'github.com', 'api'],
              ['slack', 'Slack', '42 actions', 'slack.com', 'app'],
              ['calendar', 'Calendar', '18 actions', 'calendar.google.com', 'app'],
              ['linear', 'Linear', '56 actions', 'linear.app', 'app'],
              ['resend', 'Resend', '19 actions', 'resend.com', 'api'],
              ['axiom', 'Axiom', '17 actions', 'axiom.co', 'mcp'],
            ].map(([id, name, count, domain, tag], index) => (
              <button data-source={id} class={`catalog-source mb-1 flex w-full items-center gap-2.5 rounded-md border px-2 py-2 text-left transition-colors ${index === 0 ? 'border-teal/15 bg-teal/[0.08]' : 'border-transparent hover:bg-surface-overlay'}`}>
                <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md border border-rule bg-white">
                  <img src={`https://www.google.com/s2/favicons?domain=${domain}&sz=64`} alt="" class="h-4 w-4" loading="lazy" referrerpolicy="no-referrer" />
                </div>
                <div class="min-w-0 flex-1">
                  <div class={`truncate text-[12px] ${index === 0 ? 'text-ink' : 'text-ink-muted'}`}>{name}</div>
                  <div class="text-[10px] text-ink-faint">{count}</div>
                </div>
                <span class="shrink-0 font-mono text-[9px] text-ink-faint">{tag}</span>
              </button>
            ))}
          </div>

          <div class="min-w-0 flex-1">
            <div class="border-b border-rule px-4 py-3">
              <div class="flex items-center gap-2 rounded-md border border-rule bg-surface px-3 py-2 text-[12px] text-ink-faint">
                <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
                <input
                  data-tool-search
                  type="search"
                  placeholder="Search 347 actions..."
                  class="min-w-0 flex-1 bg-transparent text-[12px] text-ink outline-none placeholder:text-ink-faint"
                  autocomplete="off"
                />
              </div>
            </div>
            <div class="relative">
              <div class="h-[340px] overflow-y-auto scrollbar-thin" data-tool-list></div>
              <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-surface-raised to-transparent" data-fade></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="computer" class="relative border-y border-rule py-28 sm:py-36">
    <div class="mx-auto grid max-w-[1200px] gap-12 px-6 sm:px-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
      <div class="reveal">
        <span class="mb-4 block font-mono text-[11px] uppercase tracking-[0.2em] text-ink-faint">Computer + browser use</span>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] tracking-tight text-ink">
          Give every agent <span class="italic text-teal">hands.</span>
        </h2>
        <div class="mt-7 grid gap-3">
          <div class="rounded-lg border border-rule bg-surface-raised p-4">
            <div class="text-[14px] font-medium text-ink">Some agents browse. Some click. Some do neither.</div>
            <p class="mt-2 text-[13px] leading-6 text-ink-muted">GOD TOOL makes browser sessions and Mac actions part of the shared interface.</p>
          </div>
          <div class="rounded-lg border border-rule bg-surface-raised p-4">
            <div class="text-[14px] font-medium text-ink">Keep browser work inside the app.</div>
            <p class="mt-2 text-[13px] leading-6 text-ink-muted">Run multiple Chromium sessions without covering your screen in windows.</p>
          </div>
          <div class="rounded-lg border border-teal/20 bg-teal/[0.05] p-4">
            <div class="text-[14px] font-medium text-teal">Save the skill once.</div>
            <p class="mt-2 text-[13px] leading-6 text-teal/70">Your computer-use routines live in GOD TOOL, not inside one model provider.</p>
          </div>
        </div>
      </div>

      <div class="reveal overflow-hidden rounded-xl border border-rule bg-surface-raised">
        <div class="flex items-center justify-between border-b border-rule px-4 py-3">
          <div class="flex items-center gap-2">
            <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
          </div>
          <div class="font-mono text-[11px] text-ink-faint">Browsers</div>
        </div>

        <div class="grid min-h-[420px] md:grid-cols-[220px_1fr]">
          <aside class="border-b border-rule bg-sidebar p-3 md:border-b-0 md:border-r">
            <div class="mb-3 flex items-center justify-between">
              <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Sessions</span>
              <span class="rounded bg-teal/[0.08] px-2 py-1 font-mono text-[10px] text-teal">3 active</span>
            </div>
            {[
              ['Research', 'docs.stripe.com'],
              ['Logged-in app', 'linear.app'],
              ['Checkout flow', 'localhost:3000'],
            ].map(([name, url], index) => (
              <div class={`mb-1 rounded-md border px-3 py-2 ${index === 0 ? 'border-teal/20 bg-teal/[0.07]' : 'border-transparent bg-surface/40'}`}>
                <div class="truncate text-[12px] font-medium text-ink">{name}</div>
                <div class="mt-1 truncate font-mono text-[10px] text-ink-faint">{url}</div>
              </div>
            ))}
            <div class="mt-5 rounded-lg border border-rule bg-surface p-3">
              <div class="font-mono text-[10px] uppercase tracking-[0.14em] text-ink-faint">Mac actions</div>
              <div class="mt-3 space-y-2 font-mono text-[11px] text-ink-muted">
                <div>click(button)</div>
                <div>type(text)</div>
                <div>read_screen()</div>
              </div>
            </div>
          </aside>

          <main class="flex min-w-0 flex-col">
            <div class="flex items-center gap-2 border-b border-rule px-3 py-2">
              <button class="rounded border border-rule px-2 py-1 text-[11px] text-ink-faint">back</button>
              <button class="rounded border border-rule px-2 py-1 text-[11px] text-ink-faint">reload</button>
              <div class="min-w-0 flex-1 rounded-md border border-rule bg-surface px-3 py-1.5 font-mono text-[11px] text-ink-muted">https://docs.stripe.com/api/payment_intents</div>
            </div>
            <div class="grid flex-1 md:grid-cols-[1fr_210px]">
              <div class="bg-black p-5 text-white">
                <div class="mb-5 flex items-center justify-between border-b border-white/10 pb-3">
                  <div class="text-lg font-semibold">Stripe Docs</div>
                  <div class="rounded bg-white/10 px-2 py-1 text-xs">API</div>
                </div>
                <div class="mb-4 h-8 w-2/3 rounded bg-white/14"></div>
                <div class="space-y-2">
                  <div class="h-3 rounded bg-white/18"></div>
                  <div class="h-3 w-11/12 rounded bg-white/14"></div>
                  <div class="h-3 w-8/12 rounded bg-white/14"></div>
                </div>
                <div class="mt-8 rounded-lg border border-white/10 bg-white/[0.06] p-4 font-mono text-xs text-emerald-200">
                  POST /v1/payment_intents<br />
                  amount: 2000<br />
                  currency: usd
                </div>
              </div>
              <div class="border-t border-rule bg-surface p-4 md:border-l md:border-t-0">
                <div class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-faint">Agent actions</div>
                <div class="mt-4 space-y-3">
                  {[
                    'open browser session',
                    'search payment intents',
                    'read API parameters',
                    'save notes to workspace',
                  ].map((step) => (
                    <div class="rounded-md border border-rule bg-surface-raised px-3 py-2 font-mono text-[11px] text-ink-muted">{step}</div>
                  ))}
                </div>
              </div>
            </div>
          </main>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-28 sm:py-36">
    <div class="mx-auto grid max-w-[1200px] gap-12 px-6 sm:px-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div class="reveal overflow-hidden rounded-xl border border-rule bg-surface-raised">
        <div class="flex items-center justify-between border-b border-rule px-4 py-3">
          <div class="font-mono text-[11px] text-ink-faint">/Users/you/GOD TOOL/workspace</div>
          <span class="rounded bg-teal/[0.08] px-2 py-1 font-mono text-[10px] text-teal">local</span>
        </div>
        <div class="grid min-h-[360px] md:grid-cols-[240px_1fr]">
          <div class="border-b border-rule bg-sidebar p-3 md:border-b-0 md:border-r">
            {[
              ['memory.md', true],
              ['skills/browser-research.md', false],
              ['automations/invoice-check.md', false],
              ['docs/launch-plan.md', false],
              ['downloads/pricing-table.csv', false],
