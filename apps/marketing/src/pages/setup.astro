---
export const prerender = true;
import Layout from "../layouts/Layout.astro";

const appUrl = "https://app.godtool.dev";
---

<Layout title="Get Started with Godtool" description="Open the Godtool app to connect sources, manage auth, and run tools.">
  <meta http-equiv="refresh" content={`0;url=${appUrl}`} slot="head" />

  <nav class="fixed top-0 z-50 w-full bg-surface/80 backdrop-blur-lg">
    <div class="mx-auto flex h-14 max-w-[1200px] items-center justify-between border-b border-rule px-6 sm:px-10">
      <a href="/" class="font-display text-xl italic tracking-tight text-ink transition-colors hover:text-teal">godtool</a>
      <div class="flex items-center gap-5 sm:gap-8">
        <a href="/privacy" class="text-[13px] text-ink-muted transition-colors hover:text-ink">Privacy</a>
        <a href="/terms" class="text-[13px] text-ink-muted transition-colors hover:text-ink">Terms</a>
        <a href="https://github.com/corporationdev/godtool" class="hidden text-[13px] text-ink-muted transition-colors hover:text-ink sm:block">GitHub</a>
      </div>
    </div>
  </nav>

  <main class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-14 sm:px-10">
    <div class="pointer-events-none absolute left-1/2 top-[20%] h-[400px] w-[600px] -translate-x-1/2 rounded-full bg-teal/[0.03] blur-[150px]"></div>
    <section class="relative mx-auto max-w-xl text-center">
      <h1 class="font-display text-[clamp(2.5rem,5vw,4rem)] leading-[1.05] tracking-tight">
        Open <span class="italic text-teal">Godtool</span>
      </h1>
      <p class="mt-5 text-[16px] leading-[1.7] text-ink-muted">
        You are being redirected to the app.
      </p>
      <a href={appUrl} class="mt-8 inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-[14px] font-medium text-primary-foreground transition-colors hover:bg-primary/90">
        Continue to app
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5H19.5M19.5 4.5V10.5M19.5 4.5L10.5 13.5"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25V19.5a1.5 1.5 0 0 1-1.5 1.5H4.5A1.5 1.5 0 0 1 3 19.5V6a1.5 1.5 0 0 1 1.5-1.5h5.25"/></svg>
      </a>
    </section>
  </main>
</Layout>
