{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "godtool-marketing-production",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "godtool.dev",
      "custom_domain": true
    },
    {
      "pattern": "www.godtool.dev",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
