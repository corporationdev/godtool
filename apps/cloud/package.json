{
  "name": "@executor/cloud",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,tunnel -c green,magenta \"bun run dev:vite\" \"bun run dev:tunnel\"",
    "dev:prepare": "bun ../../scripts/secrets-inject.ts --dev",
    "dev:vite": "bun --env-file=.env -e 'const { spawn } = require(\"node:child_process\"); const env = { ...process.env, CLOUDFLARE_INCLUDE_PROCESS_ENV: \"true\" }; if (process.env.DATABASE_URL) env.CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE = process.env.DATABASE_URL; const child = spawn(\"bun\", [\"vite\", \"dev\", \"--host\", \"127.0.0.1\", \"--port\", \"3001\"], { stdio: \"inherit\", env }); child.on(\"exit\", (code, signal) => { if (signal) process.kill(process.pid, signal); else process.exit(code ?? 0); });'",
    "dev:tunnel": "bun --env-file=.env run scripts/dev-tunnel.ts",
    "db:schema": "node --import jiti/register ../../packages/core/cli/src/index.ts generate --config ./executor.config.ts --output ./src/services/executor-schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "bun --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "db:studio:prod": "bun run db:studio",
    "db:migrate:prod": "bun run db:migrate",
    "db:migrate:prod:ci": "bun run db:migrate",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:ci": "bun run build && STAGE=prod bun --env-file=.env alchemy deploy --stage prod --adopt && STAGE=prod bun --env-file=.env run scripts/verify-deploy.ts",
    "deploy": "sh -lc 'if [ \"$CI\" != \"true\" ]; then echo \"Production deploys run in CI only.\" >&2; exit 1; fi; bun run deploy:ci'",
    "alchemy:typecheck": "tsc --noEmit --module ESNext --moduleResolution bundler --target ESNext --lib ESNext,DOM --types node,@cloudflare/workers-types --skipLibCheck --strict alchemy.run.ts",
    "cf-typegen": "wrangler types",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run && vitest run --config vitest.node.config.ts",
    "test:watch": "vitest",
    "test:node": "vitest run --config vitest.node.config.ts",
    "typecheck:slow": "tsc --noEmit"
  },
  "dependencies": {
    "@blaxel/core": "^0.2.80",
    "@cloudflare/vite-plugin": "^1.31.1",
    "@effect-atom/atom": "^0.5.0",
    "@effect-atom/atom-react": "^0.5.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "catalog:",
    "@executor/codemode-core": "workspace:*",
    "@executor/api": "workspace:*",
    "@executor/env": "workspace:*",
    "@executor/execution": "workspace:*",
    "@executor/host-mcp": "workspace:*",
    "@executor/plugin-google-discovery": "workspace:*",
    "@executor/plugin-graphql": "workspace:*",
    "@executor/plugin-mcp": "workspace:*",
    "@executor/plugin-openapi": "workspace:*",
    "@executor/plugin-workos-vault": "workspace:*",
    "@executor/react": "workspace:*",
    "@executor/runtime-dynamic-worker": "workspace:*",
    "@executor/runtime-quickjs": "workspace:*",
    "@executor/sdk": "workspace:*",
    "@executor/storage-core": "workspace:*",
    "@executor/storage-postgres": "workspace:*",
    "@microlabs/otel-cf-workers": "^1.0.0-rc.52",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "~1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/cloudflare": "^10.48.0",
    "@sentry/react": "^10.48.0",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@workos-inc/node": "^8.11.1",
    "agents": "^0.10.0",
    "autumn-js": "^1.2.8",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "jose": "^5.6.3",
    "postgres": "^3.4.9",
    "react": "catalog:",
    "react-dom": "catalog:",
    "lucide-react": "^1.7.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.3",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "^0.29.0",
    "@electric-sql/pglite": "^0.4.3",
    "@electric-sql/pglite-socket": "^0.1.3",
    "@executor/cli": "workspace:*",
    "@executor/config": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "alchemy": "^0.92.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "catalog:",
    "jiti": "^2.6.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.0"
  }
}
